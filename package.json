{
  "name": "tailwindcss-obfuscation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pkg:build": "pnpm --filter tailwindcss-obfuscator build",
    "pkg:test": "pnpm --filter tailwindcss-obfuscator test",
    "pkg:clean": "pnpm --filter tailwindcss-obfuscator clean",
    "pkg:publish": "pnpm --filter tailwindcss-obfuscator publish --access public",
    "pkg:publish:dry": "pnpm --filter tailwindcss-obfuscator publish --access public --dry-run --no-git-checks",
    "verify:obfuscation": "node scripts/verify-obfuscation.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm pkg:build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/eslint__js": "^8.42.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.18.1",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=18"
  }
}
