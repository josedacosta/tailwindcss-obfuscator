    {
      "name": "next",
      "currentMajor": 16,
      "alertOn": ["major", "breaking"],
      "githubRepo": "vercel/next.js"
    },
    { "name": "nuxt", "currentMajor": 4, "alertOn": ["major"], "githubRepo": "nuxt/nuxt" },
    { "name": "astro", "currentMajor": 6, "alertOn": ["major"], "githubRepo": "withastro/astro" },
    {
