    { "name": "rollup", "currentMajor": 4, "alertOn": ["major"], "githubRepo": "rollup/rollup" },
    { "name": "webpack", "currentMajor": 5, "alertOn": ["major"], "githubRepo": "webpack/webpack" },
    {
      "name": "esbuild",
