    { "name": "solid-js", "currentMajor": 1, "alertOn": ["major"], "githubRepo": "solidjs/solid" },
    { "name": "qwik", "currentMajor": 1, "alertOn": ["major"], "githubRepo": "QwikDev/qwik" },
    {
      "name": "tailwind-variants",
