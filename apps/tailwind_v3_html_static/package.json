{
  "name": "tailwind_v3_html_static",
  "version": "1.0.0",
  "description": "Tailwind CSS v3 HTML static project with class obfuscation",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "tw-patch install",
    "dev": "vite --port 3002",
    "build": "pnpm run extract-classes && vite build",
    "preview": "vite preview --port 3002",
    "extract-classes": "tw-patch extract",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tw-patch node_modules/.vite"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "tailwindcss-patch": "^3.0.1",
    "typescript": "^5.7.2",
    "unplugin-tailwindcss-mangle": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
