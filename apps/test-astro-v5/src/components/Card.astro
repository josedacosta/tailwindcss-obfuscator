---
interface Props {
  title: string;
  icon: string;
  description: string;
}

const { title, icon, description } = Astro.props;
---

<div class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition-shadow duration-300">
  <div class="w-14 h-14 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
    <span class="text-3xl">{icon}</span>
  </div>
  <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
  <p class="text-gray-600">{description}</p>
</div>
