---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Astro + Tailwind CSS v4">
  <main class="min-h-screen bg-gradient-to-br from-primary-50 to-accent-100 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Hero Section -->
      <header class="text-center mb-16">
        <h1 class="text-5xl font-extrabold text-gray-900 mb-6">
          Astro + Tailwind CSS v4
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Build faster websites with Astro's island architecture and Tailwind CSS v4's modern styling.
          Class obfuscation powered by tailwindcss-obfuscator.
        </p>
      </header>

      <!-- Features Grid -->
      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <Card
          title="Zero JS by Default"
          icon="🚀"
          description="Astro ships zero JavaScript to the browser by default for blazing fast performance."
        />
        <Card
          title="Island Architecture"
          icon="🏝️"
          description="Hydrate interactive components only when needed with partial hydration."
        />
        <Card
          title="Content Focused"
          icon="📝"
          description="Built for content-rich websites like blogs, marketing sites, and documentation."
        />
        <Card
          title="CSS-First Config"
          icon="🎨"
          description="Tailwind CSS v4 uses modern CSS features for faster builds and smaller output."
        />
        <Card
          title="Class Obfuscation"
          icon="🔐"
          description="Production builds have obfuscated class names for added protection."
        />
        <Card
          title="Multi-Framework"
          icon="🔧"
          description="Use React, Vue, Svelte, or any framework in your Astro project."
        />
      </section>

      <!-- CTA Section -->
      <section class="bg-white rounded-2xl shadow-lg p-8 md:p-12 text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          Ready to get started?
        </h2>
        <p class="text-gray-600 mb-8 max-w-xl mx-auto">
          Experience the power of Astro with Tailwind CSS v4 and class obfuscation.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://astro.build"
            class="px-8 py-4 bg-primary-600 text-white rounded-lg font-semibold hover:bg-primary-700 transition-colors"
          >
            Learn Astro
          </a>
          <a
            href="https://tailwindcss.com"
            class="px-8 py-4 bg-accent-500 text-white rounded-lg font-semibold hover:bg-accent-600 transition-colors"
          >
            Learn Tailwind
          </a>
        </div>
      </section>

      <!-- Footer -->
      <footer class="mt-16 text-center text-gray-500">
        <p>Built with Astro, Tailwind CSS v4, and tailwindcss-obfuscator</p>
      </footer>
    </div>
  </main>
</Layout>
