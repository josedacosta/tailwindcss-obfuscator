    "tailwind-mangle",
    "tailwind-mangler",
    "tailwindcss-mangle-alternative",
    "class-mangler",
    "class-name-mangler",
    "css-class-mangler",
    "tailwind-class-mangler",
    "tailwind-class-shortener",
    "tailwind-css-mangler",
    "minify",
    "css",
    "css-minifier",
    "vite",
    "vite-plugin",
    "webpack",
    "webpack-plugin",
    "rollup",
    "rollup-plugin",
    "esbuild",
    "esbuild-plugin",
    "rspack",
    "rspack-plugin",
    "farm",
    "farm-plugin",
    "nextjs",
    "next",
    "nuxt",
    "sveltekit",
    "svelte",
    "astro",
    "solid",
    "qwik",
    "react-router",
    "remix",
    "tanstack-router",
    "tanstack",
    "shadcn",
    "shadcn-ui",
    "cva",
    "class-variance-authority",
    "tailwind-v3",
    "tailwind-v4",
    "typescript",
    "unplugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josedacosta/tailwindcss-obfuscator.git",
    "directory": "packages/tailwindcss-obfuscator"
  },
  "homepage": "https://github.com/josedacosta/tailwindcss-obfuscator#readme",
  "bugs": {
    "url": "https://github.com/josedacosta/tailwindcss-obfuscator/issues",
    "email": "contact@josedacosta.info"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/josedacosta"
  },
  "engines": {
    "node": ">=18.0.0"
  },
