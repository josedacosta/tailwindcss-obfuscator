{
  "name": "tailwindcss-obfuscator",
  "version": "2.1.0",
  "description": "Tailwind CSS class mangler & obfuscator — rename utility classes (bg-blue-500 → tw-a) at build time. Vite, Webpack, Rollup, esbuild, Next.js, Nuxt, SvelteKit, Astro, Solid, Qwik, React Router 7, TanStack Router. Tailwind v3 + v4. Cuts CSS bundle 30–60% and protects the design system.",
  "author": {
    "name": "José DA COSTA",
    "email": "contact@josedacosta.info",
    "url": "https://github.com/josedacosta"
  },
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js",
      "require": "./dist/internals.cjs"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "import": "./dist/plugins/webpack.js",
      "require": "./dist/plugins/webpack.cjs"
    },
    "./vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.js",
      "require": "./dist/plugins/vite.cjs"
    },
    "./rollup": {
      "types": "./dist/plugins/rollup.d.ts",
      "import": "./dist/plugins/rollup.js",
      "require": "./dist/plugins/rollup.cjs"
    },
    "./esbuild": {
      "types": "./dist/plugins/esbuild.d.ts",
      "import": "./dist/plugins/esbuild.js",
      "require": "./dist/plugins/esbuild.cjs"
    },
    "./rspack": {
      "types": "./dist/plugins/rspack.d.ts",
      "import": "./dist/plugins/rspack.js",
      "require": "./dist/plugins/rspack.cjs"
    },
    "./farm": {
      "types": "./dist/plugins/farm.d.ts",
      "import": "./dist/plugins/farm.js",
      "require": "./dist/plugins/farm.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.cjs"
    },
    "./nuxt": {
      "types": "./dist/plugins/nuxt.d.ts",
      "import": "./dist/plugins/nuxt.js",
      "require": "./dist/plugins/nuxt.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "tw-obfuscator": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --exclude tests/bench",
    "test:watch": "vitest --exclude tests/bench",
    "bench": "vitest bench --run tests/bench",
    "test:integration": "node scripts/integration-build.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "magic-string": "^0.30.21",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.12",
    "postcss-selector-parser": "^7.1.1",
    "unplugin": "^2.3.11"
  },
  "devDependencies": {
    "@farmfe/core": "^1.7.11",
    "@rspack/core": "^2.0.1",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.24.2",
    "rollup": "^4.29.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.0",
    "vitest": "^4.1.5",
    "webpack": "^5.99.0"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1.7.11",
    "@rspack/core": ">=2.0.1",
    "esbuild": ">=0.28.0",
    "rollup": ">=3.30.0",
    "tailwindcss": ">=3.4.19",
    "vite": ">=4.5.14",
    "webpack": ">=5.106.2"
  },
  "peerDependenciesMeta": {
    "@farmfe/core": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "keywords": [
